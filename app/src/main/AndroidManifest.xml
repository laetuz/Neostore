<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="id.neotica.neostore">
    
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".NeostoreApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name">

        <activity android:name="id.neotica.neostore.ui.home.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity android:name=".ui.home.LoginActivity" />
        <activity android:name=".ui.home.RegisterActivity" />
        <activity android:name=".ui.home.SettingsActivity" />
        <activity android:name=".ui.detail.AppDetailActivity" />
        <activity android:name=".ui.home.AppListActivity" />
    </application>

</manifest>